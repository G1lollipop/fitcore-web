# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key

# Internal RAG service URL used by the server-side API proxy
RAG_SERVICE_URL=http://127.0.0.1:8000

# Optional: increase if first RAG calls are slow (cold start / model init)
RAG_CLIENT_TIMEOUT_MS=120000

# Optional for older AI flows still present in the app
OPENAI_API_KEY=your_openai_or_dashscope_compatible_key
